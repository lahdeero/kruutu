#!/bin/bash

errormsg="Invalid usage. Use $0 {1,2,3,4}. For example: $0 2"

tvsound() {
    local sink
    sink=$(wpctl status |
        awk '/Sinks:/,/Sources:/ {
            if ($0 ~ /GP104 High Definition Audio Controller Digital Stereo/) {
                match($0, /[0-9]+\./)
                print substr($0, RSTART, RLENGTH-1)
            }
        }')

    wpctl set-default "$sink"
}

computersound() {
    local sink
    sink=$(wpctl status |
        awk '/Sinks:/,/Sources:/ {
            if ($0 ~ /Family 17h .* Analog Stereo/) {
                match($0, /[0-9]+\./)
                print substr($0, RSTART, RLENGTH-1)
            }
        }')

    wpctl set-default "$sink"
}

disabletv() {
    if kscreen-doctor -o | grep -q '^Output: .* HDMI-A-1 '; then
        kscreen-doctor output.HDMI-A-1.disable
    fi
}

case "$1" in
    1)
        echo "DVI-D-1 + DP-1 (extended). DP-1 is the primary display on the right."
        kscreen-doctor \
            output.DVI-D-1.enable \
            output.DVI-D-1.position.0,0 \
            output.DP-1.enable \
            output.DP-1.position.1920,0 \
            output.DP-1.primary
        disabletv            
        computersound
        ;;
    2)
        echo "DP-1 + HDMI-A-1 (mirrored)"
        kscreen-doctor \
            output.DP-1.enable \
            output.DP-1.position.0,0 \
            output.DP-1.primary \
            output.HDMI-A-1.enable \
            output.HDMI-A-1.position.0,0 \
            output.DVI-D-1.disable
        tvsound
        ;;
    3)
        echo "DP-1 only"
        kscreen-doctor \
            output.DP-1.enable \
            output.DP-1.position.0,0 \
            output.DP-1.primary \
            output.DVI-D-1.disable
        disabletv
        computersound
        ;;
    4)
        echo "HDMI-A-1 + DVI-D-1 + DP-1 (HDMI left, DVI middle, DP right)"
        kscreen-doctor \
            output.HDMI-A-1.enable \
            output.HDMI-A-1.position.0,0 \
            output.DVI-D-1.enable \
            output.DVI-D-1.position.2560,0 \
            output.DP-1.enable \
            output.DP-1.position.4480,0 \
            output.DP-1.primary
        computersound
        ;;
    *)
        echo "$errormsg"
        exit 1
        ;;
esac
